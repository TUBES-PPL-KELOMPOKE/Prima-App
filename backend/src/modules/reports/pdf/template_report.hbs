<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>{{title}}</title>
    <style>
      body { font-family: Arial, Helvetica, sans-serif; font-size: 12px; color: #111; }
      .header { display:flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
      .title { font-size: 18px; font-weight: 700; }
      .meta { font-size: 11px; color: #444; text-align: right; }
      .badge { display:inline-block; padding: 2px 6px; border-radius: 6px; background:#f2f2f2; margin-right: 6px; }
      table { width: 100%; border-collapse: collapse; margin-top: 10px; }
      th, td { border: 1px solid #ddd; padding: 6px; vertical-align: top; }
      th { background: #fafafa; text-align: left; }
      .summary { margin-top: 10px; }
      pre { white-space: pre-wrap; word-break: break-word; margin: 0; }
      .muted { color: #666; }
    </style>
  </head>
  <body>
    <div class="header">
      <div>
        <div class="title">{{title}}</div>
        <div class="muted">Export Report</div>
      </div>
      <div class="meta">
        <div><span class="badge">Generated</span> {{formatDate generated_at}}</div>
        {{#if date_from}}<div><span class="badge">From</span> {{date_from}}</div>{{/if}}
        {{#if date_to}}<div><span class="badge">To</span> {{date_to}}</div>{{/if}}
      </div>
    </div>

    {{#if summary}}
      <div class="summary">
        <div style="font-weight:700; margin-bottom:6px;">Summary</div>
        <pre>{{json summary}}</pre>
      </div>
    {{/if}}

    <div style="margin-top:12px; font-weight:700;">Data</div>
    {{#if rows.length}}
      <table>
        <thead>
          <tr>
            <th style="width:36px;">No</th>
            {{#each columns}}<th>{{this}}</th>{{/each}}
          </tr>
        </thead>
        <tbody>
          {{#each rows}}
            <tr>
              <td>{{inc @index}}</td>
              {{#each ../columns}}
                <td>
                  {{#with (lookup .. this)}}
                    {{this}}
                  {{/with}}
                </td>
              {{/each}}
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <div class="muted">Tidak ada data.</div>
    {{/if}}
  </body>
</html>

